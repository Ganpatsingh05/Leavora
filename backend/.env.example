# ═══════════════════════════════════════════════
#  Leavora Backend — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in real values.

# ── MongoDB ──────────────────────────────────
# Your MongoDB Atlas connection string (or local URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/leavora?retryWrites=true&w=majority

# ── JWT Authentication ───────────────────────
# A long, random secret string (min 32 chars recommended)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-frontend-domain.com
