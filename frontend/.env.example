# ═══════════════════════════════════════════════
#  Leavora Frontend — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# All frontend env vars must start with VITE_

# ── API URL ──────────────────────────────────
# The full URL of your backend API (without trailing slash)
# Leave empty or omit in dev (Vite proxy handles it)
# Required in production when frontend & backend are on different domains
VITE_API_URL=https://your-backend-domain.com/api
